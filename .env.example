# MCP server transport. Docker Compose defaults to HTTP Streamable MCP on /mcp.
MCP_TRANSPORT=streamable-http
MCP_PORT=8000
MCP_PATH=/mcp

# Proxmox API origin. HTTPS is strongly preferred.
PVE_BASE_URL=https://proxmox.lan:8006

# API-token auth is recommended.
PVE_API_TOKEN_ID=user@pam!token-name
PVE_API_TOKEN_SECRET=replace-me

# Password-ticket auth fallback. Leave empty when using API tokens.
PVE_USERNAME=
PVE_PASSWORD=

# Use false only for self-signed/internal lab certificates.
PVE_VERIFY_SSL=false

# Keep false unless you intentionally use http:// for the Proxmox API.
PVE_ALLOW_INSECURE_HTTP=false
PVE_TIMEOUT=30
